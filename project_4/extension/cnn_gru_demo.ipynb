   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "summary-cell",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary table with percentage improvement\n",
    "for metric, gv, cv in zip(metrics, gru_vals, cnn_vals):\n",
    "    delta = (gv - cv) / gv * 100\n",
    "    direction = 'improvement' if delta > 0 else 'regression'\n",
    "    print(f'{metric:>4s}  GRU={gv:.5f}  CNN-GRU={cv:.5f}  '\n",
    "          f'Δ={abs(delta):.1f}% {direction} from CNN-GRU')"
   ]
  }
 ]
